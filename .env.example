APP_NAME=finagent-auth-service # [CONFIGMAP]
APP_ENV=development # [CONFIGMAP]
APP_HOST=0.0.0.0 # [CONFIGMAP]
APP_PORT=8001 # [CONFIGMAP]
LOG_LEVEL=INFO # [CONFIGMAP]
MYSQL_HOST=localhost # [CONFIGMAP]
MYSQL_PORT=3306 # [CONFIGMAP]
MYSQL_DATABASE=finagent_auth # [CONFIGMAP]
MYSQL_USER=finagent_auth_user # [SECRET]
MYSQL_PASSWORD=change-me # [SECRET]
JWT_SECRET_KEY=replace-with-a-long-random-value # [SECRET]
JWT_ALGORITHM=HS256 # [CONFIGMAP]
JWT_EXP_MINUTES=60 # [CONFIGMAP]
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173 # [CONFIGMAP]
RATE_LIMIT_REQUESTS=120 # [CONFIGMAP]
RATE_LIMIT_WINDOW_SECONDS=60 # [CONFIGMAP]
