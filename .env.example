APP_NAME=finagent-auth-service # [CONFIGMAP]
APP_ENV=development # [CONFIGMAP]
APP_HOST=0.0.0.0 # [CONFIGMAP]
APP_PORT=8001 # [CONFIGMAP]
GATEWAY_INBOUND_PORT=8001 # [CONFIGMAP] Internal service port exposed to the gateway proxy; this service is typically consumed via the gateway, not directly by browsers
LOG_LEVEL=INFO # [CONFIGMAP]
MYSQL_HOST=localhost # [CONFIGMAP]
MYSQL_PORT=3306 # [CONFIGMAP]
MYSQL_DATABASE=finagent_auth # [CONFIGMAP]
MYSQL_USER=finagent_auth_user # [SECRET]
MYSQL_PASSWORD=change-me # [SECRET]
MYSQL_ADMIN_HOST=localhost # [CONFIGMAP]
MYSQL_ADMIN_PORT=3306 # [CONFIGMAP]
MYSQL_ADMIN_USER=root # [SECRET]
MYSQL_ADMIN_PASSWORD=change-me-root-password # [SECRET]
MYSQL_ADMIN_DATABASE=mysql # [CONFIGMAP]
JWT_SECRET_KEY=replace-with-a-long-random-value # [SECRET]
JWT_ALGORITHM=HS256 # [CONFIGMAP]
JWT_EXP_MINUTES=60 # [CONFIGMAP]
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,https://finagent.example.com # [CONFIGMAP] Browser-facing origins only: include local frontend, local gateway, and deployed gateway origins
RATE_LIMIT_REQUESTS=120 # [CONFIGMAP]
RATE_LIMIT_WINDOW_SECONDS=60 # [CONFIGMAP]
